
    <!-- HERO -->
    <section class="page-hero tall">
      <div class="container">
        <div class="breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span class="mi" aria-hidden="true">chevron_right</span>
          <span>Reviews</span>
        </div>
        <span class="ph-eyebrow">Verified Customer Reviews</span>
        <h1 class="ph-title">Real People, Real <em>Scents</em></h1>
        <p class="ph-sub">Every review here comes from a verified purchase. No paid placements, no filtered feedback — just honest experiences from customers across the UAE who trust us for authentic fragrance and fair prices.</p>
        <div class="ph-meta">
          <span><span class="mi mi-f" aria-hidden="true">star</span>4.8 average rating</span>
          <span><span class="mi" aria-hidden="true">reviews</span>10,284 reviews</span>
          <span><span class="mi" aria-hidden="true">verified</span>100% verified purchases</span>
        </div>
      </div>
    </section>

    <!-- RATING SUMMARY + REVIEWS -->
    <section class="reviews">
      <div class="reviews-inner">
        <div class="reviews-head fade-up">
          <span class="label">The Verdict</span>
          <h2 class="sec-title">What the UAE <em>Thinks</em></h2>
        </div>
        <div class="rv-summary fade-up">
          <div class="rv-big">4.8</div>
          <div class="rv-details">
            <div class="stars">
              <span class="mi mi-f" aria-hidden="true">star</span>
              <span class="mi mi-f" aria-hidden="true">star</span>
              <span class="mi mi-f" aria-hidden="true">star</span>
              <span class="mi mi-f" aria-hidden="true">star</span>
              <span class="mi mi-f" aria-hidden="true">star</span>
            </div>
            <p>Based on 10,284 verified reviews</p>
          </div>
        </div>
        <div class="rv-grid" data-render="reviews" data-count="6"></div>
      </div>
    </section>

    <!-- FEATURED REVIEW STORY / VIDEO TESTIMONIAL -->
    <section class="section alt">
      <div class="container">
        <div class="sec-head center fade-up">
          <span class="label">Customer Story</span>
          <h2 class="sec-title">In Their Own <em>Words</em></h2>
          <p class="sec-sub">Sometimes a rating doesn't say enough. Here's a customer story worth pausing on.</p>
        </div>
        <div class="feature-article fade-up">
          <div class="fa-media" style="position:relative">
            <img src="{{ 'cat-luxury.jpg' | asset_url }}" alt="Customer video testimonial" />
            <span class="mi" aria-hidden="true" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:82px;color:#fff;filter:drop-shadow(0 6px 18px rgba(0,0,0,.5));cursor:pointer">play_circle</span>
          </div>
          <div class="fa-body">
            <span class="bl-cat">Video Testimonial · Dubai</span>
            <h2>"I stopped worrying about fakes."</h2>
            <p>"I used to buy oud on trips abroad because I never knew who to trust here. A friend recommended The Fragrance Secrets and I was sceptical — until my first order arrived sealed, genuine, and honestly cheaper than the mall. Now it's the only place I shop, and I've gifted it to half my family."</p>
            <div style="display:flex;align-items:center;gap:14px">
              <div class="rv-avatar" style="width:46px;height:46px">A</div>
              <div>
                <div class="rv-name">Aisha Mohammed</div>
                <div class="rv-meta">Verified customer · Ajman, UAE</div>
              </div>
              <div class="stars" style="margin-left:auto">
                <span class="mi mi-f" aria-hidden="true">star</span>
                <span class="mi mi-f" aria-hidden="true">star</span>
                <span class="mi mi-f" aria-hidden="true">star</span>
                <span class="mi mi-f" aria-hidden="true">star</span>
                <span class="mi mi-f" aria-hidden="true">star</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TOP-RATED PRODUCTS -->
    <section class="section">
      <div class="container">
        <div class="sec-head center fade-up">
          <span class="label">Customer Favourites</span>
          <h2 class="sec-title">Top-Rated by Our <em>Customers</em></h2>
          <p class="sec-sub">The fragrances our reviewers keep coming back to — highest rated, most loved.</p>
        </div>
        {%- if collections['featured'].products.size > 0 -%}<div class="products-grid">{%- for product in collections['featured'].products limit: 4 -%}{% render 'product-card', product: product %}{%- endfor -%}</div>{%- else -%}<div class="products-grid" data-render="products" data-count="4"></div>{%- endif -%}
        <div class="load-more-wrap">
          <a class="btn-ol" href="/collections/best-sellers">View All Best Sellers</a>
        </div>
      </div>
    </section>

    <!-- CTA — SHARE A REVIEW -->
    <section class="section">
      <div class="container">
        <div class="cta-band fade-up">
          <span class="label" style="color:var(--gold)">Your Turn</span>
          <h2 class="sec-title">Loved Your <em>Fragrance?</em></h2>
          <p class="sec-sub">Share your experience and help another perfume lover shop with confidence — or discover your next signature scent.</p>
          <div class="cta-actions">
            <a class="btn-g" href="#" onclick="waChat();return false">Share Your Review</a>
            <a class="btn-o" href="/collections/best-sellers">Browse Best Sellers</a>
          </div>
        </div>
      </div>
    </section>

{% schema %}
{ "name": "Reviews page", "settings": [] }
{% endschema %}
