{%- comment -%} All collections listing — /collections {%- endcomment -%}
<section class="page-hero tall">
  <div class="container">
    <div class="breadcrumb"><a href="{{ routes.root_url }}">Home</a><span class="mi" aria-hidden="true">chevron_right</span><span>Collections</span></div>
    <span class="ph-eyebrow">Explore</span>
    <h1 class="ph-title">Shop by <em>Collection</em></h1>
    <p class="ph-sub">Browse every curated edit — by category, scent family, lifestyle, occasion and season.</p>
  </div>
</section>

<section class="section"><div class="container">
  <div class="gender-grid collections-grid">
    {%- for collection in collections -%}
      {%- liquid
        assign col_img = collection.image | default: collection.products.first.featured_image
      -%}
      <a class="g-card fade-up" href="{{ collection.url }}">
        {%- if col_img -%}
          <img class="gc-img" src="{{ col_img | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy">
        {%- else -%}
          <span class="gc-img gc-img-fallback" aria-hidden="true"></span>
        {%- endif -%}
        <div class="gc-overlay"></div>
        <div class="gc-content">
          <div class="gc-title">{{ collection.title }}</div>
          {%- if collection.all_products_count > 0 -%}
            <div class="gc-count">{{ collection.all_products_count }} Fragrance{% unless collection.all_products_count == 1 %}s{% endunless %}</div>
          {%- endif -%}
          <span class="gc-btn">Explore</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div></section>

{% schema %}
{ "name": "List collections", "settings": [] }
{% endschema %}
