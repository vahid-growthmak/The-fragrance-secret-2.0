{%- comment -%} Single order detail {%- endcomment -%}
<section class="page-hero tall"><div class="container">
  <div class="breadcrumb"><a href="{{ routes.account_url }}">Account</a><span class="mi" aria-hidden="true">chevron_right</span><span>Order {{ order.name }}</span></div>
  <h1 class="ph-title">Order <em>{{ order.name }}</em></h1>
  <p class="ph-sub">Placed {{ order.created_at | date: '%B %-d, %Y' }} · {{ order.financial_status_label }} · {{ order.fulfillment_status_label }}</p>
</div></section>
<section class="section"><div class="container">
  <div id="cartLines">
    {%- for line in order.line_items -%}
      <div class="co-line">
        {%- if line.image -%}<span class="cl-img"><img src="{{ line.image | image_url: width: 120 }}" alt="{{ line.title | escape }}" width="60"></span>{%- endif -%}
        <div class="cl-body"><div class="cl-name">{{ line.title }}</div><div class="cl-meta">Qty {{ line.quantity }}</div></div>
        <div class="cl-price">{{ line.final_line_price | money }}</div>
      </div>
    {%- endfor -%}
  </div>
  <div class="co-totals" style="max-width:360px;margin-left:auto">
    <div class="co-trow"><span>Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
    <div class="co-trow"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
    <div class="co-trow grand"><span>Total</span><b>{{ order.total_net_amount | money }}</b></div>
  </div>
</div></section>
{% schema %}
{ "name": "Customer order", "settings": [] }
{% endschema %}
