{%- comment -%}
  Product detail page — native Shopify port of product.html.
  Driven by the `product` object (gallery, variants, price, description,
  metafields) with fallbacks so a bare product still renders the design.
{%- endcomment -%}

{%- liquid
  assign p = product
  assign cv = product.selected_or_first_available_variant
  assign brand = product.vendor | default: 'The Fragrance Secrets'
  assign rating = product.metafields.reviews.rating.value.rating | default: product.metafields.custom.rating.value | default: 4.9
  assign review_count = product.metafields.reviews.rating_count.value | default: product.metafields.custom.review_count.value | default: 0
  assign longevity = product.metafields.custom.longevity.value | default: '8–12 hours'
  assign sillage = product.metafields.custom.sillage.value | default: 'Strong'
  assign best_for = product.metafields.custom.best_for.value | default: 'Evening / Party'
  assign origin = product.metafields.custom.origin.value | default: 'UAE'
  assign notes_top = product.metafields.custom.notes_top.value
  assign notes_heart = product.metafields.custom.notes_heart.value
  assign notes_base = product.metafields.custom.notes_base.value
  assign badge = product.metafields.custom.badge.value | default: 'Bestseller'
  assign mf = product.metafields.custom
  assign fragrance_experience = mf.fragrance_experience.value
  assign best_for_details = mf.best_for_details.value
  assign faq = mf.faq.value
-%}

<main-product class="page active" id="product" data-product>
  <!-- BREADCRUMB HERO -->
  <div class="pdp-hero">
    <div class="pdp-hero-inner">
      <div class="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="mi" aria-hidden="true">chevron_right</span>
        {%- if collection -%}
          <a href="{{ collection.url }}">{{ collection.title }}</a>
          <span class="mi" aria-hidden="true">chevron_right</span>
        {%- endif -%}
        <span>{{ product.title }}</span>
      </div>
    </div>
  </div>

  {%- form 'product', product, id: 'product-form', class: 'pdp-form' -%}
    <input type="hidden" name="id" value="{{ cv.id }}">

    <section class="pdp-main">
      <div class="pdp-main-inner">

        <!-- GALLERY -->
        <div class="pdp-gallery">
          <div class="thumb-list" id="thumblist">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media limit: 6 -%}
                <div class="thumb{% if forloop.first %} active{% endif %}" data-full="{{ media | image_url: width: 900 }}"><img src="{{ media | image_url: width: 160 }}" alt="View {{ forloop.index }}"></div>
              {%- endfor -%}
            {%- else -%}
              <div class="thumb active" data-full="{{ 'prod-bouquet-oud.png' | asset_url }}"><img src="{{ 'prod-bouquet-oud.png' | asset_url }}" alt="View 1"></div>
              <div class="thumb" data-full="{{ 'hero-oud.jpg' | asset_url }}"><img src="{{ 'hero-oud.jpg' | asset_url }}" alt="View 2"></div>
              <div class="thumb" data-full="{{ 'prod-shaghaf.png' | asset_url }}"><img src="{{ 'prod-shaghaf.png' | asset_url }}" alt="View 3"></div>
            {%- endif -%}
          </div>
          <div class="main-img-wrap">
            {%- if product.featured_media -%}
              <img class="main-img" id="mainimg" src="{{ product.featured_media | image_url: width: 900 }}" alt="{{ product.title | escape }}">
            {%- else -%}
              <img class="main-img" id="mainimg" src="{{ 'prod-bouquet-oud.png' | asset_url }}" alt="{{ product.title | escape }}">
            {%- endif -%}
            {%- if badge != blank -%}<div class="img-badge">{{ badge }}</div>{%- endif -%}
            <div class="zoom-hint"><span class="mi" aria-hidden="true">zoom_in</span>Hover to zoom</div>
          </div>
        </div>

        <!-- INFO -->
        <div class="pdp-info">
          <div class="pdp-brand">{{ brand }}</div>
          <h1 class="pdp-title">{{ product.title }}</h1>
          <div class="pdp-rating-row">
            {% render 'star-rating', rating: rating %}
            <span class="rv-count">{{ review_count }} reviews</span>
            <a href="#pdp-reviews" class="rv-link">Read reviews</a>
          </div>
          <div class="pdp-price-row" data-price-row>
            <span class="pdp-price-now">{{ cv.price | money }}</span>
            {%- if cv.compare_at_price > cv.price -%}
              <span class="pdp-price-was">{{ cv.compare_at_price | money }}</span>
              <span class="pdp-price-save">Save {{ cv.compare_at_price | minus: cv.price | times: 100.0 | divided_by: cv.compare_at_price | round }}%</span>
            {%- endif -%}
          </div>

          <!-- REASSURANCE -->
          <div class="urgency-block" style="background:rgba(201,168,76,.07);border-color:rgba(201,168,76,.22)">
            <div class="ub-stock" style="color:var(--gold-dk)"><span class="mi" aria-hidden="true">local_shipping</span>
              {%- if cv.available -%}In stock — ships within 48 hours{%- else -%}Currently out of stock{%- endif -%}
            </div>
            <div class="ub-sep" style="background:rgba(201,168,76,.3)"></div>
            <div class="ub-views"><span class="mi" aria-hidden="true">verified_user</span>Authenticity guaranteed · 7-day returns</div>
          </div>

          <!-- CTA BLOCK (primary action — kept above the fold) -->
          <div class="cta-block">
            <div class="qty-row">
              <div class="qty-wrap">
                <button type="button" class="qty-btn" onclick="changeQty(-1)">&minus;</button>
                <input class="qty-num" id="qtynum" name="quantity" type="text" value="1" readonly>
                <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
              </div>
              <button type="submit" name="add" class="atc-btn"{% unless cv.available %} disabled{% endunless %}><span class="mi" aria-hidden="true">shopping_bag</span>{% if cv.available %}Add to Cart{% else %}Sold Out{% endif %}</button>
            </div>
            {{ form | payment_button }}
            {% render 'pay-icons' %}
            <p class="pay-note">Pay later, interest-free in 4 with <span class="pay-chip pay-chip-inline pay-tabby" title="Tabby">tabby</span> &amp; <span class="pay-chip pay-chip-inline pay-tamara" title="Tamara">tamara</span> · <span class="pay-chip pay-chip-inline pay-cod" title="Cash on Delivery"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.4"/></svg>COD</span> available UAE-wide</p>
            {%- if product.type contains 'Oil' or product.type contains 'Attar' or product.tags contains 'oil' or product.tags contains 'attar' -%}
            <button type="button" class="mix-cta" onclick="openMix('{{ product.title | escape | replace: "'", "\\'" }}')">
              <span class="mi" aria-hidden="true">science</span>
              Mix It Into a Spray
              <span class="mix-tag">50 / 100ml</span>
            </button>
            {%- endif -%}
          </div>

          <!-- KEY INFO -->
          <div class="key-info">
            <div class="ki-item"><div class="ki-icon"><span class="mi" aria-hidden="true">schedule</span></div><div class="ki-label">Longevity</div><div class="ki-val">{{ longevity }}</div></div>
            <div class="ki-item"><div class="ki-icon"><span class="mi" aria-hidden="true">air</span></div><div class="ki-label">Projection</div><div class="ki-val">{{ sillage }}</div></div>
            <div class="ki-item"><div class="ki-icon"><span class="mi" aria-hidden="true">person</span></div><div class="ki-label">Best For</div><div class="ki-val">{{ best_for }}</div></div>
            <div class="ki-item"><div class="ki-icon"><span class="mi" aria-hidden="true">public</span></div><div class="ki-label">Made In</div><div class="ki-val">{{ origin }}</div></div>
          </div>

          <!-- FRAGRANCE FAMILY + NOTES -->
          {%- if mf.fragrance_family.value != blank -%}
          <div class="fragrance-family">
            <span class="ff-label">Fragrance Family</span>
            <span class="ff-val">{{ mf.fragrance_family.value | replace: ', ', ' • ' }}</span>
          </div>
          {%- endif -%}
          {%- if notes_top or notes_heart or notes_base -%}
          <div class="notes-block">
            <div class="notes-title">Fragrance Notes</div>
            <div class="notes-row">
              {%- if notes_top -%}<span class="note-tag"><strong>Top</strong>{{ notes_top }}</span>{%- endif -%}
              {%- if notes_heart -%}<span class="note-tag"><strong>Heart</strong>{{ notes_heart }}</span>{%- endif -%}
              {%- if notes_base -%}<span class="note-tag"><strong>Base</strong>{{ notes_base }}</span>{%- endif -%}
            </div>
          </div>
          {%- endif -%}

          <!-- TRUST -->
          <div class="pdp-trust">
            <div class="pt-item"><span class="mi" aria-hidden="true">verified_user</span><span><strong>100% Authentic Perfumes</strong> — Sourced from trusted suppliers</span></div>
            <div class="pt-item"><span class="mi" aria-hidden="true">local_shipping</span><span><strong>Free Delivery</strong> — On orders above AED 150</span></div>
            <div class="pt-item"><span class="mi" aria-hidden="true">autorenew</span><span><strong>Easy Returns</strong> — Eligible damaged or incorrect orders only</span></div>
            <div class="pt-item"><span class="mi" aria-hidden="true">lock</span><span><strong>Secure Payments</strong> — Visa, Mastercard, Apple Pay &amp; Cash on Delivery</span></div>
            <a href="/pages/sourcing-promise" class="pt-link">Read our Sourcing Promise <span class="mi" aria-hidden="true">arrow_forward</span></a>
          </div>

          <!-- TABS — one per detail section, driven by metafields -->
          <div class="pdp-tabs">
            <div class="tab-header">
              <button type="button" class="tab-btn active" onclick="switchTab(this,'desc')">Description</button>
              {%- if best_for_details != blank -%}<button type="button" class="tab-btn" onclick="switchTab(this,'bestfor')">Best For</button>{%- endif -%}
              <button type="button" class="tab-btn" onclick="switchTab(this,'specs')">Specifications</button>
              <button type="button" class="tab-btn" onclick="switchTab(this,'ship')">Shipping &amp; Returns</button>
            </div>
            <div class="tab-content">
              <!-- Description -->
              <div class="tab-pane active" id="desc">
                {%- if product.description != blank -%}{{ product.description }}
                {%- else -%}<p>Crafted for those who want to stand out, this fragrance blends deep, resonant notes with warmth and sharpness — a truly magnetic presence that commands attention from the first spray.</p>{%- endif -%}
              </div>

              <!-- Best For -->
              {%- if best_for_details != blank -%}
              <div class="tab-pane" id="bestfor">
                <ul>
                  {%- assign bf_lines = best_for_details | strip | newline_to_br | split: '<br />' -%}
                  {%- for line in bf_lines -%}{%- assign l = line | strip -%}{%- if l != blank -%}<li>{{ l }}</li>{%- endif -%}{%- endfor -%}
                </ul>
              </div>
              {%- endif -%}

              <!-- Specifications (two-column grid) -->
              <div class="tab-pane" id="specs">
                {%- comment -%} Collect present specs as "Label|Value" items, then split into two independent columns {%- endcomment -%}
                {%- capture specs_raw -%}
                  {%- if product.vendor != blank -%}Brand|{{ product.vendor }}~|~{%- endif -%}
                  {%- if mf.fragrance_family.value != blank -%}Fragrance Family|{{ mf.fragrance_family.value }}~|~{%- endif -%}
                  {%- if mf.concentration.value != blank -%}Concentration|{{ mf.concentration.value }}~|~{%- endif -%}
                  {%- if mf.size.value != blank -%}Size|{{ mf.size.value }}~|~{%- elsif cv.title != 'Default Title' -%}Size|{{ cv.title }}~|~{%- endif -%}
                  {%- if mf.product_form.value != blank -%}Product Form|{{ mf.product_form.value }}~|~{%- endif -%}
                  {%- if mf.dispenser.value != blank -%}Dispenser|{{ mf.dispenser.value }}~|~{%- endif -%}
                  {%- if mf.gender.value != blank -%}Gender|{{ mf.gender.value }}~|~{%- endif -%}
                  {%- if mf.occasion.value != blank -%}Occasion|{{ mf.occasion.value }}~|~{%- endif -%}
                  {%- if mf.bottle_colour.value != blank -%}Bottle Colour|{{ mf.bottle_colour.value }}~|~{%- endif -%}
                  {%- if mf.longevity.value != blank -%}Longevity|{{ mf.longevity.value }}~|~{%- endif -%}
                  {%- if mf.ships_to.value != blank -%}Ships To|{{ mf.ships_to.value }}~|~{%- endif -%}
                  {%- if mf.barcode.value != blank -%}Barcode|{{ mf.barcode.value }}~|~{%- endif -%}
                {%- endcapture -%}
                {%- assign spec_list = specs_raw | strip | split: '~|~' -%}
                {%- assign spec_half = spec_list.size | plus: 1 | divided_by: 2 -%}
                <div class="spec-cols">
                  {%- for col in (1..2) -%}
                  <div class="spec-col">
                    <div class="spec-item spec-head{% if col == 2 %} spec-head-2{% endif %}"><span class="spec-k">Product Details</span><span class="spec-v">Information</span></div>
                    {%- for item in spec_list -%}
                      {%- assign in_left = false -%}
                      {%- if forloop.index0 < spec_half -%}{%- assign in_left = true -%}{%- endif -%}
                      {%- if col == 1 and in_left -%}
                        {%- assign kv = item | strip | split: '|' -%}
                        <div class="spec-item"><span class="spec-k">{{ kv[0] }}</span><span class="spec-v">{{ kv[1] }}</span></div>
                      {%- elsif col == 2 and in_left == false -%}
                        {%- assign kv = item | strip | split: '|' -%}
                        <div class="spec-item"><span class="spec-k">{{ kv[0] }}</span><span class="spec-v">{{ kv[1] }}</span></div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- endfor -%}
                </div>
              </div>

              <!-- Shipping & Returns -->
              <div class="tab-pane" id="ship">
                <h4>Shipping Information</h4>
                <p>We deliver across the UAE within 1–4 business days. Orders placed after 6:00 PM (UAE Time) are processed the next business day. Shipping costs AED 8, and tracking details are shared once your order has been dispatched.</p>
                <h4>Return Policy</h4>
                <p>Returns are accepted within 2 days only for damaged, defective, incorrect, or incomplete orders. Products must remain unused, sealed, and in their original packaging. Opened perfume bottles and change-of-mind returns cannot be accepted.</p>
              </div>
            </div>
          </div>
        </div><!-- /pdp-info -->
      </div><!-- /pdp-main-inner -->
    </section>
  {%- endform -%}

  <!-- FAQ — full width, below the product image and details -->
  {%- if faq != blank -%}
  <section class="section pdp-faq">
    <div class="container" style="max-width:900px">
      <div class="sec-head center">
        <span class="label">Your Questions, Answered</span>
        <h2 class="sec-title">Frequently Asked <em>Questions</em></h2>
      </div>
      <div class="faq-list">
        {%- assign faq_lines = faq | strip | newline_to_br | split: '<br />' -%}
        {%- for line in faq_lines -%}
          {%- assign qa = line | split: ' :: ' -%}
          {%- if qa.size >= 2 -%}
          <details class="faq-item">
            <summary class="faq-q">{{ qa[0] | strip }}<span class="mi" aria-hidden="true">add</span></summary>
            <div class="faq-a">{{ qa[1] | strip }}</div>
          </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  <!-- PDP REVIEWS -->
  <section class="pdp-reviews" id="pdp-reviews">
    <div class="pdp-rv-inner">
      <div class="reviews-head fade-up"><span class="label">Verified Reviews</span><h2 class="sec-title">What Customers <em>Say</em></h2></div>
      <!-- Start of Judge.me code -->
      {% assign has_legacy = false %}{% if product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'></div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>{% endif %}</div>{% if product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>{% endif %}
      <!-- End of Judge.me code -->
    </div>
  </section>

  <!-- RELATED PRODUCTS -->
  <section class="related">
    <div class="related-inner">
      <div class="related-head fade-up"><span class="label">Complete the Set</span><h2 class="sec-title">You May Also <em>Like</em></h2></div>
      {%- assign related = product.metafields.custom.related.value | default: recommendations.products -%}
      {%- if collection.products.size > 1 -%}
        <div class="products-grid">
          {%- for prod in collection.products limit: 4 -%}
            {%- unless prod.id == product.id -%}{% render 'product-card', product: prod %}{%- endunless -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="products-grid" data-render="products" data-count="4"></div>
      {%- endif -%}
    </div>
  </section>

  <!-- MORE FROM THIS BRAND -->
  {%- assign brand_count = 0 -%}
  {%- for p in collections.all.products -%}
    {%- if p.vendor == product.vendor and p.id != product.id -%}{%- assign brand_count = brand_count | plus: 1 -%}{%- endif -%}
  {%- endfor -%}
  {%- if brand_count > 0 -%}
  <section class="related">
    <div class="related-inner">
      <div class="related-head fade-up"><span class="label">The House</span><h2 class="sec-title">More from <em>{{ product.vendor }}</em></h2></div>
      <div class="products-grid">
        {%- assign shown = 0 -%}
        {%- for p in collections.all.products -%}
          {%- if p.vendor == product.vendor and p.id != product.id and shown < 4 -%}
            {% render 'product-card', product: p %}
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div style="text-align:center;margin-top:30px">
        <a class="btn-o" href="/collections/vendors?q={{ product.vendor | url_encode }}" style="color:var(--ink);border-color:rgba(13,10,6,.28)">View all {{ product.vendor }} perfumes<span class="mi" aria-hidden="true">arrow_forward</span></a>
      </div>
    </div>
  </section>
  {%- endif -%}

  <!-- BEST SELLERS -->
  {%- if collections['best-sellers'].products.size > 0 -%}
  <section class="related">
    <div class="related-inner">
      <div class="related-head fade-up"><span class="label">Loved by Many</span><h2 class="sec-title">Our <em>Best Sellers</em></h2></div>
      <div class="products-grid">
        {%- assign shown = 0 -%}
        {%- for p in collections['best-sellers'].products -%}
          {%- if p.id != product.id and shown < 4 -%}{% render 'product-card', product: p %}{%- assign shown = shown | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  <!-- WHY CUSTOMERS CHOOSE THE FRAGRANCE SECRETS -->
  <section class="section why-choose">
    <div class="container">
      <div class="sec-head center">
        <span class="label">Why Shop With Us</span>
        <h2 class="sec-title">Why Customers Choose <em>The Fragrance Secrets</em></h2>
      </div>
      <div class="why-grid">
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">verified</span><h3>100% Authentic Perfumes</h3></div>
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">local_shipping</span><h3>Fast UAE Delivery</h3></div>
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">lock</span><h3>Secure Payments</h3></div>
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">diamond</span><h3>Premium Fragrance Collection</h3></div>
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">inventory_2</span><h3>Carefully Packed Orders</h3></div>
        <div class="why-card fade-up"><span class="mi" aria-hidden="true">redeem</span><h3>Perfect for Gifting</h3></div>
      </div>
    </div>
  </section>

  <!-- STICKY ATC BAR -->
  <div class="sticky-atc" id="stickyatc">
    <div class="sticky-atc-inner">
      <span class="prod-name-mini">{{ product.title }}</span>
      <span class="price-mini">{{ cv.price | money }}</span>
      <button type="button" class="atc-mini" onclick="document.getElementById('product-form').requestSubmit()">Add to Cart</button>
    </div>
  </div>
</main-product>

{% schema %}
{
  "name": "Product page",
  "settings": [],
  "presets": [ { "name": "Product page" } ]
}
{% endschema %}
