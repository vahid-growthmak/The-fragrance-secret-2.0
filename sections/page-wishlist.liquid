
    <style>
    /* ── Wishlist ── */
    .wish-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
    .wish-toolbar .wish-count { font-size: .86rem; color: var(--warm); }
    .wish-toolbar .wish-count b { color: var(--ink); }
    .wish-card .prod-info { display: flex; flex-direction: column; }
    .wish-actions { display: flex; gap: 8px; margin-top: 14px; }
    .wish-actions .btn-g { flex: 1; justify-content: center; padding: 11px 14px; font-size: .74rem; }
    .wish-remove {
      width: 44px; flex-shrink: 0; border: 1px solid var(--cream-dk); border-radius: 8px; background: var(--white);
      color: var(--muted); display: flex; align-items: center; justify-content: center; transition: all .2s;
    }
    .wish-remove:hover { border-color: #C0392B; color: #C0392B; background: rgba(192, 57, 43, .05); }
    .wish-remove .mi { font-size: 19px; }
    /* Empty state */
    .wish-empty { display: none; text-align: center; max-width: 520px; margin: 20px auto 0; padding: 40px 0; }
    .wish-empty.show { display: block; }
    .wish-empty .we-ic { width: 84px; height: 84px; border-radius: 50%; margin: 0 auto 22px; display: flex; align-items: center; justify-content: center; background: var(--cream-mid); border: 1px solid var(--cream-dk); }
    .wish-empty .we-ic .mi { font-size: 40px; color: var(--gold-dk); }
    .wish-empty h3 { font-family: var(--fd); font-weight: 400; font-size: 1.9rem; margin-bottom: 10px; }
    .wish-empty p { color: var(--warm); font-size: .92rem; margin-bottom: 24px; }
    /* Single-column on standard phones so Move-to-Cart + remove sit comfortably */
    @media (max-width: 560px) {
      #wishGrid { grid-template-columns: 1fr; gap: 16px; }
      .wish-card { display: grid; grid-template-columns: 116px 1fr; align-items: stretch; }
      .wish-card .prod-img-wrap { height: 100%; }
      .wish-card .prod-img { height: 100%; object-fit: cover; }
      .wish-card .prod-info { padding: 14px 14px 14px 16px; }
      .wish-toolbar .btn-g { width: 100%; justify-content: center; }
    }
    @media (max-width: 360px) {
      .wish-card { grid-template-columns: 96px 1fr; }
      .wish-actions .btn-g { font-size: .72rem; padding: 11px 8px; }
    }
    </style>

    <div class="crumb-bar">
