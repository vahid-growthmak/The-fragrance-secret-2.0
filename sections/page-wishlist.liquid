    <!-- KEEP EXPLORING -->
    <section class="section alt">
      <div class="container">
        <div class="sec-head center fade-up"><span class="label">Keep Exploring</span><h2 class="sec-title">More to <em>Discover</em></h2></div>
        {%- if collections['featured'].products.size > 0 -%}<div class="products-grid">{%- for product in collections['featured'].products limit: 4 -%}{% render 'product-card', product: product %}{%- endfor -%}</div>{%- else -%}<div class="products-grid" data-render="products" data-count="4"></div>{%- endif -%}
      </div>
    </section>

  <script>
    function updateWishCount() {
      var n = document.querySelectorAll('#wishGrid .wish-card').length;
      var numEl = document.getElementById('wishNum');
      if (numEl) numEl.textContent = n;
      var empty = document.getElementById('wishEmpty');
      var grid = document.getElementById('wishGrid');
      var toolbar = document.getElementById('wishToolbar');
      if (n === 0) {
        if (empty) empty.classList.add('show');
        if (grid) grid.style.display = 'none';
        if (toolbar) toolbar.style.display = 'none';
      }
    }
    function moveToCart(btn) {
      var card = btn.closest('.wish-card');
      var name = card.querySelector('.prod-name').textContent.trim();
      card.remove();
      if (typeof bumpCart === 'function') bumpCart(1);
      if (typeof toast === 'function') toast('✓ Moved to cart — ' + name);
      updateWishCount();
    }
    function wishRemove(btn) {
      var card = btn.closest('.wish-card');
      var name = card.querySelector('.prod-name').textContent.trim();
      card.remove();
      if (typeof toast === 'function') toast('Removed — ' + name);
      updateWishCount();
    }
    function addAllToCart() {
      var cards = document.querySelectorAll('#wishGrid .wish-card');
      var count = cards.length;
      if (!count) return;
      cards.forEach(function (c) { c.remove(); });
      if (typeof bumpCart === 'function') bumpCart(count);
      if (typeof toast === 'function') toast('✓ ' + count + ' fragrances moved to cart');
      updateWishCount();
    }
  </script>

