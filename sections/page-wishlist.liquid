              <div class="prod-price"><span class="price-now">AED 179</span><span class="price-was">AED 240</span><span class="price-save">Save 25%</span></div>
              <div class="wish-actions">
                <button class="btn-g" onclick="moveToCart(this)"><span class="mi" aria-hidden="true">shopping_bag</span>Move to Cart</button>
