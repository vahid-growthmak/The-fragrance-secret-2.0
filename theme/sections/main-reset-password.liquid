{%- comment -%} Reset password {%- endcomment -%}
<section class="page-hero tall"><div class="container"><h1 class="ph-title">Reset <em>Password</em></h1></div></section>
<section class="section"><div class="container" style="max-width:460px">
  {%- form 'reset_customer_password' -%}
    {{ form.errors | default_errors }}
    <label>New password</label><input type="password" name="customer[password]" class="fld" required>
    <label style="margin-top:12px">Confirm password</label><input type="password" name="customer[password_confirmation]" class="fld" required>
    <button type="submit" class="btn-g" style="width:100%;margin-top:14px">Reset Password</button>
  {%- endform -%}
</div></section>
{% schema %}
{ "name": "Reset password", "settings": [] }
{% endschema %}
