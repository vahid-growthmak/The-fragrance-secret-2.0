{%- comment -%} All collections listing — /collections {%- endcomment -%}
<section class="page-hero tall">
  <div class="container">
    <div class="breadcrumb"><a href="{{ routes.root_url }}">Home</a><span class="mi" aria-hidden="true">chevron_right</span><span>Collections</span></div>
    <span class="ph-eyebrow">Explore</span>
    <h1 class="ph-title">Shop by <em>Collection</em></h1>
    <p class="ph-sub">Browse every curated edit — by category, scent family, lifestyle, occasion and season.</p>
  </div>
</section>

<section class="section"><div class="container">
  <div class="cat-grid">
    {%- for collection in collections -%}
      <a class="cat-card fade-up" href="{{ collection.url }}">
        <div class="cat-img-wrap">
          {%- if collection.image -%}
            <img class="cat-img" src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy">
          {%- elsif collection.products.first.featured_image -%}
            <img class="cat-img" src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy">
          {%- endif -%}
        </div>
        <div class="cat-info">
          <h3 class="cat-name">{{ collection.title }}</h3>
          <span class="cat-count">{{ collection.all_products_count }} products</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div></section>

{% schema %}
{ "name": "List collections", "settings": [] }
{% endschema %}
