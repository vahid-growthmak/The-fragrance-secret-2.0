{%- comment -%} Storefront password page {%- endcomment -%}
<section class="page-hero tall"><div class="container" style="text-align:center">
  {%- if shop.logo -%}<img src="{{ shop.logo | image_url: width: 320 }}" alt="{{ shop.name }}" style="max-width:180px">{%- else -%}<img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="max-width:180px">{%- endif -%}
  <span class="ph-eyebrow" style="margin-top:20px">Opening Soon</span>
  <h1 class="ph-title">{{ shop.name }}</h1>
  <p class="ph-sub" style="margin-left:auto;margin-right:auto">{{ page_description | default: 'Authentic luxury perfumes, coming soon.' }}</p>
  <div style="max-width:420px;margin:28px auto 0">
    {%- form 'storefront_password' -%}
      {{ form.errors | default_errors }}
      <label>Enter store password</label>
      <input type="password" name="password" class="fld" placeholder="Password">
      <button type="submit" class="btn-g" style="width:100%;margin-top:14px">Enter</button>
    {%- endform -%}
  </div>
</div></section>
{% schema %}
{ "name": "Password", "settings": [] }
{% endschema %}
