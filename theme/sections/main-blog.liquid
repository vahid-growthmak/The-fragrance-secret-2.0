{%- comment -%} Blog listing (Guides hub) — native port of journal.html grid. {%- endcomment -%}
<section class="page-hero tall">
  <div class="container">
    <div class="breadcrumb"><a href="{{ routes.root_url }}">Home</a><span class="mi" aria-hidden="true">chevron_right</span><span>{{ blog.title }}</span></div>
    <span class="ph-eyebrow">The Journal</span>
    <h1 class="ph-title">{{ blog.title }}</h1>
    <p class="ph-sub">Guides, comparisons and expert advice to help you find, layer and care for your fragrances.</p>
  </div>
</section>

<section class="blog"><div class="container">
  {%- paginate blog.articles by 12 -%}
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <a class="bl-card" href="{{ article.url }}">
          <div class="bl-img-wrap">
            {%- if article.image -%}<img class="bl-img" src="{{ article.image | image_url: width: 700 }}" alt="{{ article.title | escape }}" loading="lazy">{%- endif -%}
          </div>
          {%- if article.tags.size > 0 -%}<div class="bl-cat">{{ article.tags.first }}</div>{%- endif -%}
          <div class="bl-title">{{ article.title }}</div>
          <div class="bl-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 26 }}</div>
          <div class="bl-meta">{{ article.published_at | date: '%B %-d, %Y' }}{% if article.reading_time %} · {{ article.reading_time }}{% endif %}</div>
        </a>
      {%- else -%}
        <p class="sec-sub">No articles yet — check back soon.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <div class="pagination">
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}<span class="current">{{ part.title }}</span>
          {%- else -%}<span>{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div></section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
