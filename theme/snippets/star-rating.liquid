{%- comment -%} Renders 5 stars, gold up to `rating` (rounded). Ported from app.js starsHTML(). {%- endcomment -%}
{%- assign r = rating | default: 0 | round -%}
<div class="stars">
  {%- for i in (1..5) -%}
    <span class="mi mi-f" aria-hidden="true" style="color:{% if forloop.index <= r %}var(--gold){% else %}var(--cream-dk){% endif %}">star</span>
  {%- endfor -%}
</div>
